# Copy this file to .env and fill in values. Never commit .env.
# All vars are prefixed with ALP_ (see app/config.py).

# ---------------------------------------------------------------------------
# Supabase (required) — https://supabase.com/dashboard
# Project Settings → API
# ---------------------------------------------------------------------------
ALP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
ALP_SUPABASE_ANON_KEY=
ALP_SUPABASE_SERVICE_ROLE_KEY=
# Project Settings → API → JWT Secret
ALP_SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# AI provider
# ---------------------------------------------------------------------------
# "gemini" is recommended (~13x cheaper than Haiku for this task).
# "anthropic" uses Claude. "none" disables AI.
ALP_AI_PROVIDER=gemini
ALP_GEMINI_API_KEY=
ALP_GEMINI_MODEL=gemini-1.5-flash
ALP_ANTHROPIC_API_KEY=
ALP_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Deterministic cleanup (usaddress + heuristics) — free, always safe.
ALP_ENABLE_DETERMINISTIC_CLEANUP=true
# Global AI cleanup toggle. In prod, leave this false — AI gets enabled
# automatically for users with an active Pro subscription.
ALP_ENABLE_AI_CLEANUP=false

# ---------------------------------------------------------------------------
# Stripe — monthly Pro subscription
# ---------------------------------------------------------------------------
# Dashboard → Developers → API keys (use sk_test_... until ready for live)
ALP_STRIPE_SECRET_KEY=
ALP_STRIPE_PUBLISHABLE_KEY=
# Dashboard → Developers → Webhooks → Signing secret (whsec_...)
ALP_STRIPE_WEBHOOK_SECRET=
# Dashboard → Products → create a recurring monthly Price → paste its id
ALP_STRIPE_PRO_PRICE_ID=
ALP_STRIPE_PRODUCT_NAME=AddressLabelPro Pro

# Public URL of the frontend (Stripe redirects here after Checkout)
ALP_FRONTEND_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Rate limits (per user when authed, per IP otherwise)
# ---------------------------------------------------------------------------
ALP_RATE_LIMIT_UPLOAD_PER_HOUR=20
ALP_RATE_LIMIT_MAP_PER_HOUR=60
ALP_RATE_LIMIT_GENERATE_PER_HOUR=60

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
ALP_DEBUG=false
ALP_MAX_FILE_SIZE_MB=50
ALP_DEFAULT_COUNTRY=US
